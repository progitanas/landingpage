RewriteEngine On

# Canonical URL for landing 1.
RewriteRule ^mutuelle-senior/comparatif/01/?$ /senior/comp1 [R=302,L,QSA]

# Serve the main landing page while keeping clean landing URLs visible.
RewriteRule ^senior/comp1/?$ /index.html [L]
RewriteRule ^senior/comp2/?$ /index1.html [L]
RewriteRule ^senior/comp3/?$ /index2.html [L]
RewriteRule ^senior/comp4/?$ /index3.html [L]
RewriteRule ^senior/comp5/?$ /index4.html [L]
RewriteRule ^senior/comp6/?$ /index5.html [L]
RewriteRule ^senior/comp7/?$ /index6.html [L]
RewriteRule ^senior/comp8/?$ /index7.html [L]
RewriteRule ^senior/comp9/?$ /index8.html [L]
RewriteRule ^senior/comp10/?$ /index9.html [L]
RewriteRule ^senior/comp11/?$ /index10.html [L]