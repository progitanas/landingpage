RewriteEngine On

# Serve the main landing page while keeping clean landing URLs visible.
RewriteRule ^senior/comp1/?$ /index.html [L]
RewriteRule ^senior/comp2/?$ /index1.html [L]
RewriteRule ^senior/comp3/?$ /index2.html [L]
RewriteRule ^senior/comp4/?$ /index3.html [L]
RewriteRule ^senior/comp5/?$ /index4.html [L]
RewriteRule ^senior/comp6/?$ /index5.html [L]
RewriteRule ^senior/comp7/?$ /index6.html [L]
RewriteRule ^senior/comp8/?$ /index7.html [L]
RewriteRule ^senior/comp9/?$ /index8.html [L]
RewriteRule ^senior/comp10/?$ /index9.html [L]
RewriteRule ^senior/comp11/?$ /index10.html [L]

# Also support long URLs for email campaigns.
RewriteRule ^mutuelle-senior/comparatif/01/?$ /index.html [L]
RewriteRule ^mutuelle-senior/comparatif/02/?$ /index1.html [L]
RewriteRule ^mutuelle-senior/comparatif/03/?$ /index2.html [L]
RewriteRule ^mutuelle-senior/comparatif/04/?$ /index3.html [L]
RewriteRule ^mutuelle-senior/comparatif/05/?$ /index4.html [L]
RewriteRule ^mutuelle-senior/comparatif/06/?$ /index5.html [L]
RewriteRule ^mutuelle-senior/comparatif/07/?$ /index6.html [L]
RewriteRule ^mutuelle-senior/comparatif/08/?$ /index7.html [L]
RewriteRule ^mutuelle-senior/comparatif/09/?$ /index8.html [L]
RewriteRule ^mutuelle-senior/comparatif/10/?$ /index9.html [L]
RewriteRule ^mutuelle-senior/comparatif/11/?$ /index10.html [L]

# Basic hardening rules (effective only if ModSecurity is enabled by host).
<IfModule mod_security2.c>
	SecRuleEngine On

	# Block common attack signatures in query strings.
	SecRule QUERY_STRING "(?i)(union(?:[\\s\\+]+all)?[\\s\\+]+select|select[\\s\\+].+[\\s\\+]+from|<script|onerror[\\s\\+]*=|javascript:|%3Cscript|\\.\\./|%2e%2e%2f)" "id:10010,phase:2,deny,status:403,log,msg:'Suspicious query blocked'"

	# Block known scanners and exploitation tools.
	SecRule REQUEST_HEADERS:User-Agent "(?i)(sqlmap|nikto|masscan|nmap|zgrab|acunetix|nessus)" "id:10011,phase:1,deny,status:403,log,msg:'Scanner user-agent blocked'"
</IfModule>